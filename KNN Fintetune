dataframe = pd.read_csv("customers.csv")

# features and target
X = dataframe[["Age", "MonthlyIncome"]]
Y = dataframe["Purchased"]

#split data
X_train, X_test, Y_train, Y_test = train_test_split(
    X, Y, test_size=0.2, random_state=42
)

# KNN model (k = 3 neighbors)
model = KNeighborsClassifier(
    n_neighbors=3,
    metric='euclidean',
    weights='uniform'
)

model.fit(X_train, Y_train)

predictions = model.predict(X_test)

# print results
print("Test customers:")
print(X_test.values)

print("Predictions:")
print(predictions)

print("Actual:")
print(Y_test.values)

# accuracy
accuracy = accuracy_score(Y_test, predictions)
